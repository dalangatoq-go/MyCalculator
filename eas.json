{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug",
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    },
    "production": {
      "env": {
        "EAS_BUILD_SKIP_LOCKFILE_CHECK": "1"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      }
    },
    "production-apk": {
      "env": {
        "EAS_BUILD_SKIP_LOCKFILE_CHECK": "1"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
