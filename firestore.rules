rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // TOLAK SEMUA AKSES SECARA DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // ── RUANG PUBLIK ──────────────────────────────────────────────
    match /general_chat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['text', 'userAlias', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.userAlias is string;
      allow update, delete: if false;
    }

    // ── RUANG CHAT PRIVAT ─────────────────────────────────────────
    match /{roomId}/{messageId} {
      allow read: if roomId.matches('private_.+') && request.auth != null;
      allow create: if roomId.matches('private_.+')
                    && request.auth != null
                    && request.resource.data.keys().hasAll(['text', 'userAlias', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.userAlias is string;
      allow update, delete: if false;
    }

    // ── FCM TOKENS (untuk push notifikasi) ───────────────────────
    // Hanya user yang login bisa tulis token miliknya sendiri.
    // Cloud Functions membaca dengan service account (bypass rules).
    match /fcm_tokens/{aliasId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── PRESENCE (status online/offline & terakhir aktif) ────────
    // Semua user yang login boleh baca status siapa saja (perlu untuk
    // lampu online di daftar kontak), tapi hanya field online/lastActive
    // yang boleh ditulis — tidak ada data lain yang bisa disisipkan.
    match /presence/{aliasId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.keys().hasOnly(['online', 'lastActive'])
                   && request.resource.data.online is bool
                   // lastActive wajib timestamp server saat ini (serverTimestamp()),
                   // bukan angka/tanggal sembarang kiriman client.
                   && request.resource.data.lastActive == request.time;
    }

  }
}
