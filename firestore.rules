rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TOLAK SEMUA AKSES SECARA DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // AKSES RUANG OBROLAN — hanya user yang sudah sign in (anonymous)
    // Catatan: anonymous auth digunakan lewat kode stealth di kalkulator
    match /general_chat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['text', 'userAlias', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.userAlias is string;
      allow update, delete: if false;
    }
  }
}
