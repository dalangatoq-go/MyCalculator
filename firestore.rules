rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // TOLAK SEMUA AKSES SECARA DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // ── RUANG PUBLIK ──────────────────────────────────────────────
    match /general_chat/{messageId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['text', 'userAlias', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.userAlias is string
                    // senderUid opsional (backward compat), tapi jika ada harus == auth.uid
                    && (!request.resource.data.keys().hasAny(['senderUid'])
                        || request.resource.data.senderUid == request.auth.uid);

      // Hanya pengirim asli (via senderUid) yang boleh menghapus pesannya sendiri.
      allow delete: if request.auth != null
                    && resource.data.senderUid == request.auth.uid;

      allow update: if false;
    }

    // ── RUANG CHAT PRIVAT ─────────────────────────────────────────
    match /{roomId}/{messageId} {
      allow read: if roomId.matches('private_.+') && request.auth != null;

      allow create: if roomId.matches('private_.+')
                    && request.auth != null
                    && request.resource.data.keys().hasAll(['text', 'userAlias', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.userAlias is string
                    // senderUid opsional (backward compat), tapi jika ada harus == auth.uid
                    && (!request.resource.data.keys().hasAny(['senderUid'])
                        || request.resource.data.senderUid == request.auth.uid);

      // Hanya pengirim asli (via senderUid) yang boleh menghapus pesannya sendiri.
      allow delete: if request.auth != null
                    && resource.data.senderUid == request.auth.uid;

      allow update: if false;
    }

    // ── FCM TOKENS (untuk push notifikasi) ───────────────────────
    // Client hanya boleh MENULIS token miliknya sendiri.
    // Cloud Functions membaca dengan service account (bypass rules).
    match /fcm_tokens/{aliasId} {
      allow read:   if false;
      allow write:  if request.auth != null
                    && request.resource.data.keys().hasOnly(['token'])
                    && request.resource.data.token is string
                    && request.resource.data.token.size() > 0;
      allow delete: if false;
    }

    // ── PRESENCE (status online/offline & terakhir aktif) ────────
    match /presence/{aliasId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.keys().hasOnly(['online', 'lastActive'])
                   && request.resource.data.online is bool
                   && request.resource.data.lastActive == request.time;
      allow delete: if false;
    }

  }
}
