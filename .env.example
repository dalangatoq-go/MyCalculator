# Dipakai oleh src/utils/pushNotify.js untuk kirim notifikasi chat
# langsung dari client ke OneSignal REST API (karena Firebase Cloud
# Functions belum bisa dipakai tanpa paket Blaze/billing).
#
# EXPO_PUBLIC_* di-inline oleh Metro/Expo ke dalam bundle saat build,
# jadi nilainya akan ikut terbawa ke APK -- lihat catatan keamanan di
# src/utils/pushNotify.js.
#
# Lokal (development/expo start): copy file ini ke `.env` lalu isi nilainya.
# EAS Build (cloud): sudah diset lewat `eas env:create`, tidak perlu file ini.
EXPO_PUBLIC_ONESIGNAL_REST_API_KEY=
